# Kimi Code Web Assistant 环境变量配置

# 数据库配置
DATABASE_URL=postgresql://username:password@localhost:5432/kimi_assistant

# 服务器配置
PORT=3000
NODE_ENV=development
ROOT_DIR=/path/to/your/code

# 客户端 URL（用于 CORS）
CLIENT_URL=http://localhost:5173

# 会话密钥
SESSION_SECRET=your-secret-key-here

# ============================================
# 火山引擎语音服务配置（可选）
# ============================================
# 如果没有配置，将使用本地 Piper TTS 和浏览器 STT

# 火山引擎 App ID
VOLCANO_APP_ID=your-volcano-app-id

# 火山引擎 Access Key（用于TTS，从控制台获取）
VOLCANO_ACCESS_KEY=your-access-key

# 火山引擎 Secret Key（用于TTS签名，从控制台获取）
VOLCANO_SECRET_KEY=your-secret-key

# 火山引擎 Access Token（用于STT）
VOLCANO_ACCESS_TOKEN=your-volcano-access-token

# 火山引擎集群（可选，默认使用流式识别）
VOLCANO_CLUSTER=volcengine_streaming_common

# 获取火山引擎密钥：
# 1. 访问 https://www.volcengine.com/
# 2. 注册并登录账号
# 3. 进入"语音识别"和"语音合成"服务
# 4. 创建应用并获取 App ID、Access Key、Secret Key 和 Access Token
